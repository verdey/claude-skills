#!/usr/bin/env bash
# sr-rename <old-pattern> <new-pattern> [path] [--dry-run]
# Bulk rename files matching pattern. fd + mv composition.
# Always dry-run first.
set -euo pipefail

OLD="${1:?Missing: old pattern. Usage: sr-rename <old-pattern> <new-pattern> [path] [--dry-run]}"
NEW="${2:?Missing: new pattern. Usage: sr-rename <old-pattern> <new-pattern> [path] [--dry-run]}"
shift 2

TARGET="."
DRY_RUN=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run) DRY_RUN=true ;;
        *) TARGET="$1" ;;
    esac
    shift
done

FILES=$(fd "$OLD" "$TARGET" --type f 2>/dev/null || true)

if [[ -z "$FILES" ]]; then
    echo "No files matching '$OLD' in $TARGET"
    exit 0
fi

FILE_COUNT=$(echo "$FILES" | wc -l | tr -d ' ')

if [[ "$DRY_RUN" == true ]]; then
    echo "DRY RUN — $FILE_COUNT file(s) would be renamed:"
    echo ""
    echo "$FILES" | while IFS= read -r f; do
        dir=$(dirname "$f")
        base=$(basename "$f")
        newbase=$(echo "$base" | sed "s/$OLD/$NEW/g")
        echo "  $f → $dir/$newbase"
    done
else
    echo "$FILES" | while IFS= read -r f; do
        dir=$(dirname "$f")
        base=$(basename "$f")
        newbase=$(echo "$base" | sed "s/$OLD/$NEW/g")
        mv "$f" "$dir/$newbase"
        echo "  $f → $dir/$newbase"
    done
    echo "Renamed $FILE_COUNT file(s)."
fi
