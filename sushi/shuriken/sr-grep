#!/usr/bin/env bash
# sr-grep <pattern> [path] [-A N] [-B N] [--glob pattern]
# Context-windowed grep. rg-powered. Heading-grouped output.
set -euo pipefail

PATTERN="${1:?Missing: pattern. Usage: sr-grep <pattern> [path] [-A N] [-B N] [--glob pattern]}"
shift
PATH_ARG="."
AFTER=3
BEFORE=2
GLOB_ARG=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -A) shift; AFTER="${1:-3}" ;;
        -B) shift; BEFORE="${1:-2}" ;;
        --glob) shift; GLOB_ARG="--glob ${1:-}" ;;
        *) PATH_ARG="$1" ;;
    esac
    shift
done

rg --color=never -n --heading -A "$AFTER" -B "$BEFORE" $GLOB_ARG "$PATTERN" "$PATH_ARG" 2>/dev/null || echo "No matches."
