#!/usr/bin/env bash
# sr-scaffold <manifest-file> [base-path]
# Create directory/file tree from plain-text manifest.
# Manifest format: one path per line. Trailing / = directory. Otherwise = file.
set -euo pipefail

MANIFEST="${1:?Missing: manifest file. Usage: sr-scaffold <manifest-file> [base-path]}"
BASE="${2:-.}"

if [[ ! -f "$MANIFEST" ]]; then
    echo "Manifest file not found: $MANIFEST"
    exit 1
fi

COUNT=0
while IFS= read -r path || [[ -n "$path" ]]; do
    # Skip empty lines and comments
    [[ -z "$path" || "$path" == \#* ]] && continue

    full="$BASE/$path"
    if [[ "$path" == */ ]]; then
        mkdir -p "$full"
    else
        mkdir -p "$(dirname "$full")"
        touch "$full"
    fi
    COUNT=$((COUNT + 1))
    echo "  created: $full"
done < "$MANIFEST"

echo "Scaffolded $COUNT entries from $MANIFEST"
